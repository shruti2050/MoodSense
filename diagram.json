{
  "version": 1,
  "author": "Shruti Joshi",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0 },

    { "type": "wokwi-led", "id": "led", "top": 40, "left": -180 },
    { "type": "wokwi-resistor", "id": "r1", "top": 150, "left": -130, "attrs": { "value": "220" } },

    { "type": "wokwi-potentiometer", "id": "pot", "top": -100, "left": -120 }
  ],

  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["led:A", "esp:D2", "green", []],
    ["led:C", "r1:1", "green", []],
    ["r1:2", "esp:GND.2", "green", []],

    ["pot:VCC", "esp:3V3", "red", []],
    ["pot:GND", "esp:GND.1", "black", []],
    ["pot:SIG", "esp:34", "green", []]
  ]
}